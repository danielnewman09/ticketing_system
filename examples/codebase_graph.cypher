CREATE CONSTRAINT compound_refid IF NOT EXISTS FOR (n:Compound) REQUIRE n.refid IS UNIQUE;
CREATE CONSTRAINT file_refid IF NOT EXISTS FOR (n:File) REQUIRE n.refid IS UNIQUE;
CREATE CONSTRAINT member_refid IF NOT EXISTS FOR (n:Member) REQUIRE n.refid IS UNIQUE;
CREATE CONSTRAINT namespace_refid IF NOT EXISTS FOR (n:Namespace) REQUIRE n.refid IS UNIQUE;
CREATE INDEX compound_kind IF NOT EXISTS FOR (n:Compound) ON (n.kind);
CREATE INDEX compound_name IF NOT EXISTS FOR (n:Compound) ON (n.name);
CREATE INDEX compound_qualified IF NOT EXISTS FOR (n:Compound) ON (n.qualified_name);
CREATE FULLTEXT INDEX doc_search IF NOT EXISTS FOR (n:Compound|Member) ON EACH [n.name, n.qualified_name, n.brief_description, n.detailed_description];
CREATE INDEX file_name IF NOT EXISTS FOR (n:File) ON (n.name);
CREATE INDEX file_path IF NOT EXISTS FOR (n:File) ON (n.path);
CREATE INDEX member_kind IF NOT EXISTS FOR (n:Member) ON (n.kind);
CREATE INDEX member_name IF NOT EXISTS FOR (n:Member) ON (n.name);
CREATE INDEX member_qualified IF NOT EXISTS FOR (n:Member) ON (n.qualified_name);
CREATE INDEX namespace_name IF NOT EXISTS FOR (n:Namespace) ON (n.name);

