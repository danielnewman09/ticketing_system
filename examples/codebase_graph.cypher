CREATE (:Compound {base_classes: [], brief_description: 'Manages a single WebSocket live simulation session.', detailed_description: 'Each session creates an isolated Engine instance so that physics state
is fully independent across concurrent connections.

Lifecycle:
    1. Client sends ``configure`` — server constructs Engine, spawns objects,
       sends ``metadata``.
    2. Client sends ``start`` — server streams ``frame`` messages.
    3. Client may send ``stop`` at any time; server sends ``complete``.', file_path: '', is_abstract: false, is_final: false, kind: 'class', line_number: 85, name: 'LiveSimulationSession', qualified_name: 'replay.routes.live.LiveSimulationSession', refid: 'py_class_replay_routes_live_LiveSimulationSession'});
