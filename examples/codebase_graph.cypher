CREATE (:Member {argsstring: '()', brief_description: 'Compute maximum relative energy drift.', compound_refid: 'py_class_replay_testing_recording_query_RecordingQuery', definition: '', detailed_description: 'Calculates max |E(t) - E(0)| / |E(0)| across all frames, where E(0) is
