CREATE (:Member {argsstring: '(Coordinate origin, const Coordinate &xDirection, const Coordinate &zDirection)', brief_description: 'Constructor from local X and Z axes (right-hand rule).', compound_refid: 'classmsd__sim_1_1_reference_frame', definition: 'msd_sim::ReferenceFrame::ReferenceFrame', detailed_description: 'Constructs a reference frame from two vectors representing the local X-axis (tangent direction) and Z-axis (normal direction). The Y-axis is computed using the cross product Y = Z × X to follow the right-hand rule. The input vectors do not need to be normalized or perfectly orthogonal - they will be processed as follows: Z is normalized (takes precedence as the primary/normal direction) X is orthogonalized against Z and normalized Y is computed as Z × X This is useful for constructing a local coordinate frame based on a surface normal (Z) and tangent direction (X), common in collision response. origin The origin of this frame in global coordinates xDirection Vector representing the local positive X-axis direction zDirection Vector representing the local positive Z-axis direction std::invalid_argument if either vector is zero or if vectors are parallel', file_path: '/Users/danielnewman/dev/MSD-CPP_1/msd/msd-sim/src/Environment/ReferenceFrame.hpp', is_const: false, is_constexpr: false, is_explicit: false, is_inline: false, is_static: false, is_virtual: false, kind: 'function', line_number: 97, name: 'ReferenceFrame', protection: 'public', qualified_name: 'msd_sim::ReferenceFrame::ReferenceFrame', refid: 'classmsd__sim_1_1_reference_frame_1acfcc78feef0571965bafdc015c51bf02', type: ''});
