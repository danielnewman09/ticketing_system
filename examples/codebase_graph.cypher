CREATE (:Compound {base_classes: ['cpp_sqlite::BaseTransferObject'], brief_description: 'Transfer record for friction constraint state.', detailed_description: 'Records the tangent basis and parameters of a friction constraint after constraint creation. Enables visualization of contact frames (normal + two orthogonal tangents) and debugging of friction force magnitudes. Note: All vector fields (normal, tangents, lever arms) are Vector3DRecord (directions), not CoordinateRecord (points), to avoid globalToLocal overload issues when transforming between reference frames.', file_path: '/Users/danielnewman/dev/MSD-CPP_1/msd/msd-transfer/src/FrictionConstraintRecord.hpp', is_abstract: false, is_final: false, kind: 'struct', line_number: 23, name: 'FrictionConstraintRecord', qualified_name: 'msd_transfer::FrictionConstraintRecord', refid: 'structmsd__transfer_1_1_friction_constraint_record'});
CREATE (:Compound {base_classes: ['cpp_sqlite::BaseTransferObject'], brief_description: 'Database record for complete kinematic state.', detailed_description: 'Stores the 14-component state vector (X, Q, Ẋ, Q̇) plus acceleration for an msd_sim::InertialState . Uses composition of existing record types for each member. Components: position: 3D spatial coordinate [m] velocity: Linear velocity [m/s] acceleration: Linear acceleration [m/s²] orientation: Unit quaternion (w, x, y, z) quaternionRate: Quaternion time derivative Q̇ angularAcceleration: Angular acceleration [rad/s²] body: Foreign key to AssetInertialStaticRecord for body identification frame: Foreign key to SimulationFrameRecord for timestamping msd_sim::InertialState Ticket:\\n 0038_simulation_data_recorder Ticket:\\n 0056i_static_asset_recording_and_fk', file_path: '/Users/danielnewman/dev/MSD-CPP_1/msd/msd-transfer/src/InertialStateRecord.hpp', is_abstract: false, is_final: false, kind: 'struct', line_number: 46, name: 'InertialStateRecord', qualified_name: 'msd_transfer::InertialStateRecord', refid: 'structmsd__transfer_1_1_inertial_state_record'});
