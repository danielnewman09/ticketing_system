CREATE (:Compound {base_classes: ['Eigen::Vector3d'], brief_description: 'Angular acceleration vector [rad/s^2] without normalization.', detailed_description: 'Inherits from Eigen::Vector3d for full matrix operation support. Provides semantic pitch/roll/yaw accessors without any normalization. Axis convention (ZYX intrinsic rotation): pitch: Rotation around Y-axis (component 0) roll: Rotation around X-axis (component 1) yaw: Rotation around Z-axis (component 2) Memory footprint: 24 bytes (same as Eigen::Vector3d)', file_path: '/Users/danielnewman/dev/MSD-CPP_1/msd/msd-sim/src/DataTypes/AngularAcceleration.hpp', is_abstract: false, is_final: true, kind: 'class', line_number: 26, name: 'AngularAcceleration', qualified_name: 'msd_sim::AngularAcceleration', refid: 'classmsd__sim_1_1_angular_acceleration'});
CREATE (:Compound {base_classes: ['Eigen::Vector3d'], brief_description: 'Orientation angles with deferred normalization.', detailed_description: 'Inherits from Eigen::Vector3d for full matrix operation support. Provides semantic pitch/roll/yaw accessors. Normalization strategy: Values are normalized to (-π, π] only when |value| exceeds kNormalizationThreshold Check occurs in assignment and compound operators (+=, -=, *=, /=) Accessors return raw values (fast, no normalization check) Use normalized() or normalize() for explicit normalization to (-π, π] LIMITATION: Direct access via operator[] bypasses normalization. Use semantic accessors ( pitch() , roll() , yaw() ) and setters for normal use. Axis convention (ZYX intrinsic rotation): pitch: Rotation around Y-axis (component 0) roll: Rotation around X-axis (component 1) yaw: Rotation around Z-axis (component 2) Memory footprint: 24 bytes (same as Eigen::Vector3d) docs/designs/0024_angular_coordinate/0024_angular_coordinate.puml Ticket:\\n 0024_angular_coordinate', file_path: '/Users/danielnewman/dev/MSD-CPP_1/msd/msd-sim/src/DataTypes/AngularCoordinate.hpp', is_abstract: false, is_final: true, kind: 'class', line_number: 43, name: 'AngularCoordinate', qualified_name: 'msd_sim::AngularCoordinate', refid: 'classmsd__sim_1_1_angular_coordinate'});
CREATE (:Compound {base_classes: ['Eigen::Vector3d'], brief_description: 'Angular velocity vector [rad/s] without normalization.', detailed_description: 'Inherits from Eigen::Vector3d for full matrix operation support. Provides semantic pitch/roll/yaw accessors without any normalization. Rates can exceed 2pi rad/s and should not be normalized. Axis convention (ZYX intrinsic rotation): pitch: Rotation around Y-axis (component 0) roll: Rotation around X-axis (component 1) yaw: Rotation around Z-axis (component 2) Memory footprint: 24 bytes (same as Eigen::Vector3d)', file_path: '/Users/danielnewman/dev/MSD-CPP_1/msd/msd-sim/src/DataTypes/AngularVelocity.hpp', is_abstract: false, is_final: true, kind: 'class', line_number: 27, name: 'AngularVelocity', qualified_name: 'msd_sim::AngularVelocity', refid: 'classmsd__sim_1_1_angular_velocity'});
CREATE (:Compound {base_classes: ['msd_sim::AssetPhysical'], brief_description: 'Stationary geometric element with no rigid body dynamics.', detailed_description: 'AssetEnvironment represents static, immovable objects in the simulation environment. These assets inherit visual geometry, convex hull, and reference frame from AssetPhysical , but have no rigid body properties and cannot be moved by forces or interactions. Key features: Visual geometry for rendering (inherited) Convex hull for collision detection (inherited) Reference frame defining position and orientation (inherited) Always stationary (no dynamics) Lightweight compared to InertialAsset (no mass properties) Provides zero mass/inertia for unified solver path (Ticket 0032) Typical use cases: Terrain and ground surfaces Buildings and structures Static obstacles Environmental boundaries Walls and barriers Usage pattern: auto geometry = std::make_shared<msd_assets::Geometry>(...); ReferenceFrame frame(Coordinate(10, 0, 0)); // Position at x=10 auto asset = AssetEnvironment::create(geometry, frame); // Use for rendering renderer.draw(asset->getVisualGeometry(), asset->getReferenceFrame()); // Use for collision detection if (asset->getCollisionHull().contains(point)) { // Handle collision with static environment } Ticket:\\n 0032_contact_constraint_refactor', file_path: '/Users/danielnewman/dev/MSD-CPP_1/msd/msd-sim/src/Physics/RigidBody/AssetEnvironment.hpp', is_abstract: false, is_final: false, kind: 'class', line_number: 54, name: 'AssetEnvironment', qualified_name: 'msd_sim::AssetEnvironment', refid: 'classmsd__sim_1_1_asset_environment'});
CREATE (:Compound {base_classes: ['msd_sim::AssetPhysical'], brief_description: 'Dynamic geometric element with full rigid body physics.', detailed_description: 'AssetInertial extends AssertPhysical by adding rigid body dynamics properties (mass, inertia tensor, center of mass) and dynamic state (velocities and accelerations). These assets can be acted upon by forces, collide with other objects, and move according to the laws of physics. Key features: Visual geometry for rendering (inherited) Convex hull for collision detection (inherited) Reference frame defining position and orientation (inherited) Rigid body properties (mass, inertia tensor, center of mass) Dynamic state (linear/angular velocity and acceleration) Can participate in physics simulations Automatic mass property computation from geometry Typical use cases: Movable objects (boxes, spheres, etc.) Vehicles and characters Projectiles Debris and destructible objects Any object that responds to forces and collisions Usage pattern: auto geometry = std::make_shared<msd_assets::Geometry>(...); ReferenceFrame frame(Coordinate(5, 0, 10)); // Initial position auto asset = AssetInertial::create(geometry, 50.0, frame); // 50 kg mass // Use for rendering renderer.draw(asset->getVisualGeometry(), asset->getReferenceFrame()); // Use for physics const auto & props = asset->getPhysicsProperties(); asset->getDynamicState().setLinearVelocity(Coordinate(1, 0, 0)); applyForce (force, asset->getReferenceFrame()); // Update position and orientation after physics step asset->getReferenceFrame().setOrigin(newPosition);', file_path: '/Users/danielnewman/dev/MSD-CPP_1/msd/msd-sim/src/Physics/RigidBody/AssetInertial.hpp', is_abstract: false, is_final: false, kind: 'class', line_number: 53, name: 'AssetInertial', qualified_name: 'msd_sim::AssetInertial', refid: 'classmsd__sim_1_1_asset_inertial'});
CREATE (:Compound {base_classes: [], brief_description: 'Base class for geometric elements in the simulation.', detailed_description: 'AssetPhysical is the base class for all geometric objects in the simulation, providing visual geometry, collision detection via convex hull, and a reference frame defining position and orientation in world space. This class serves as the foundation for: EnvironmentAsset: Stationary objects with no dynamics InertialAsset: Dynamic objects with rigid body properties Key features: Visual geometry for rendering Convex hull for collision detection (computed lazily) Reference frame defining position and orientation in world space Shared ownership model for efficient memory usage Usage pattern: // Typically used via derived classes EnvironmentAsset or InertialAsset auto geometry = std::make_shared<msd_assets::Geometry>(...); ReferenceFrame frame(Coordinate(10, 0, 0)); auto asset = EnvironmentAsset::create(geometry, frame); // Access base class functionality const auto & hull = asset->getCollisionHull(); const auto & frame = asset->getReferenceFrame();', file_path: '/Users/danielnewman/dev/MSD-CPP_1/msd/msd-sim/src/Physics/RigidBody/AssetPhysical.hpp', is_abstract: false, is_final: false, kind: 'class', line_number: 43, name: 'AssetPhysical', qualified_name: 'msd_sim::AssetPhysical', refid: 'classmsd__sim_1_1_asset_physical'});
CREATE (:Compound {base_classes: [], brief_description: '', detailed_description: '', file_path: '/Users/danielnewman/dev/MSD-CPP_1/msd/msd-sim/src/Agent/BaseAgent.hpp', is_abstract: false, is_final: false, kind: 'class', line_number: 6, name: 'BaseAgent', qualified_name: 'msd_sim::BaseAgent', refid: 'classmsd__sim_1_1_base_agent'});
CREATE (:Compound {base_classes: [], brief_description: 'Orchestrates collision detection algorithms (GJK/EPA).', detailed_description: 'Provides a unified interface for collision detection that: Runs GJK to detect intersection If collision detected, runs EPA to compute contact info Returns std::optional to indicate collision presence This abstraction allows future enhancements (broadphase, continuous collision detection, etc.) without changing callers. docs/designs/0027a_expanding_polytope_algorithm/0027a_expanding_polytope_algorithm.puml Ticket:\\n 0027a_expanding_polytope_algorithm', file_path: '/Users/danielnewman/dev/MSD-CPP_1/msd/msd-sim/src/Physics/Collision/CollisionHandler.hpp', is_abstract: false, is_final: false, kind: 'class', line_number: 31, name: 'CollisionHandler', qualified_name: 'msd_sim::CollisionHandler', refid: 'classmsd__sim_1_1_collision_handler'});
CREATE (:Compound {base_classes: [], brief_description: 'Orchestrates collision response pipeline with warm-starting and position correction.', detailed_description: 'Extracts the collision detection, constraint creation, solver invocation, cache management, and position correction logic from WorldModel into a dedicated orchestrator class with independently testable phases. The pipeline executes the following phases: Collision Detection — O(n²) pairwise narrow-phase checks Contact Constraint Creation — Factory calls to build ContactConstraint objects Solver Input Assembly — Gathering states, masses, inertias 3.5. Warm-Starting — Query ContactCache for previous frame\'s lambdas Constraint Solving — Active Set Method with initial lambda 4.5. Cache Update — Store solved lambdas in ContactCache Force Application — Apply solved constraint forces to inertial bodies Position Correction — Split-impulse penetration correction Design rationale: Separates concerns ( WorldModel manages simulation lifecycle, CollisionPipeline implements collision response algorithm), improves testability (each phase can be unit-tested independently), and enhances extensibility (easier to add broadphase culling or friction). Thread safety: Not thread-safe (contains mutable state in member vectors) Error handling: Empty asset spans handled gracefully (early return) Solver non-convergence propagated from ConstraintSolver No exceptions thrown for normal operation docs/designs/0044_collision_pipeline_integration/0044_collision_pipeline_integration.puml Ticket:\\n 0044_collision_pipeline_integration', file_path: '/Users/danielnewman/dev/MSD-CPP_1/msd/msd-sim/src/Physics/Collision/CollisionPipeline.hpp', is_abstract: false, is_final: false, kind: 'class', line_number: 68, name: 'CollisionPipeline', qualified_name: 'msd_sim::CollisionPipeline', refid: 'classmsd__sim_1_1_collision_pipeline'});
CREATE (:Compound {base_classes: [], brief_description: 'Abstract base class for constraint definitions in Lagrangian mechanics.', detailed_description: 'Defines the mathematical interface for arbitrary constraints C(q, t) that can be enforced via Lagrange multipliers. Each constraint implementation provides: Constraint function evaluation C(qA, qB, t) for two bodies Constraint Jacobian J = ∂C/∂q Optional time derivative ∂C/∂t Baumgarte stabilization parameters (α, β) Lagrange multiplier bounds (bilateral/unilateral/box-constrained) Body count and indices for solver dispatch Lagrange multiplier formulation: J·M⁻¹·Jᵀ·λ = -J·M⁻¹·F_ext - J̇·q̇ - α·C - β·Ċ F_constraint = Jᵀ·λ Unified Evaluation Signature: All constraints use a two-body signature evaluate(stateA, stateB, time). Single-body constraints ignore stateB. This eliminates LSP violations and enables polymorphic treatment of all constraint types. Convenience Overloads: Non-virtual convenience methods evaluate(state, time) and jacobian(state, time) delegate to the two-body virtual methods, passing state as both stateA and stateB. Jacobian Column Count: Single-body constraints ( bodyCount() == 1): dimension × 7 (position-level DOFs) Two-body constraints ( bodyCount() == 2): dimension × 12 (velocity-level DOFs) Thread safety: Implementations must be thread-safe for concurrent evaluation (read-only after construction). Error handling: Implementations may throw std::invalid_argument for invalid state or parameters. docs/designs/0043_constraint_hierarchy_refactor/0043_constraint_hierarchy_refactor.puml Ticket:\\n 0043_constraint_hierarchy_refactor', file_path: '/Users/danielnewman/dev/MSD-CPP_1/msd/msd-sim/src/Physics/Constraints/Constraint.hpp', is_abstract: true, is_final: false, kind: 'class', line_number: 60, name: 'Constraint', qualified_name: 'msd_sim::Constraint', refid: 'classmsd__sim_1_1_constraint'});
CREATE (:Compound {base_classes: [], brief_description: 'Partitions constraints into independent contact islands via union-find.', detailed_description: 'Uses union-find (disjoint set) to partition a flat constraint list into independent connected components. Two bodies are connected if they share at least one constraint. Environment bodies (index >= numInertialBodies) are intentionally excluded from connectivity: two inertial bodies touching the same floor remain in separate islands, because environment bodies have infinite mass and are unperturbed by contacts. This is a pure orchestration utility for CollisionPipeline . It produces island subsets that are passed to ConstraintSolver::solve() individually, reducing the effective mass matrix from O((3C)³) global to O(Σᵢ (3Cᵢ)³) per-island. Complexity: O(n · α(n)) where α is the inverse Ackermann function (effectively O(n) total for all operations). Thread safety: Stateless static utility — safe to call from any thread. Error handling: Returns empty vector for empty input. No exceptions thrown. docs/designs/0071a_constraint_solver_scalability/design.md docs/designs/0071a_constraint_solver_scalability/0071a_constraint_solver_scalability.puml Ticket:\\n 0071a_constraint_solver_scalability', file_path: '/Users/danielnewman/dev/MSD-CPP_1/msd/msd-sim/src/Physics/Constraints/ConstraintIslandBuilder.hpp', is_abstract: false, is_final: false, kind: 'class', line_number: 40, name: 'ConstraintIslandBuilder', qualified_name: 'msd_sim::ConstraintIslandBuilder', refid: 'classmsd__sim_1_1_constraint_island_builder'});
CREATE (:Compound {base_classes: [], brief_description: 'Per-frame typed free-list pool for constraint objects.', detailed_description: 'Maintains two contiguous backing stores — one for ContactConstraint , one for FrictionConstraint . After the first frame the backing vectors have grown to their high-water mark; subsequent reset() calls clear the vectors without releasing capacity, achieving zero heap allocation for constraint objects in steady state. Implementation note: Uses reserve() + emplace_back() + clear() rather than resize() + assignment because ContactConstraint and FrictionConstraint have no default constructors. clear() calls trivial virtual destructors (no owned resources) and preserves capacity, so subsequent emplace_back() calls reuse the allocated memory. Pointer stability: Pointers returned by allocate*() are valid until the next reset() call. Callers must not store pointers across frames. Frame lifecycle (pointer safety guarantee): reset() — clear counts, preserve capacity allocate*() batch — all emplace_back calls for this frame Solver, position correction, recording — read-only pointer usage Next frame — goto 1 There is no interleaving of grow and use within a frame. When the vector must grow (first frame or new high-water mark), all pointers already stored in allConstraints_ from this frame would be invalidated — but because all allocations happen in the createConstraints() batch before any pointer is stored, this is safe. Extensibility: New constraint types (joints, limits) add a new typed backing vector and a corresponding allocate*() method. No changes are needed to existing allocation paths. Thread safety: Not thread-safe (single-threaded physics loop assumed). docs/designs/0071g_constraint_pool_allocation/design.md Ticket:\\n 0071g_constraint_pool_allocation', file_path: '/Users/danielnewman/dev/MSD-CPP_1/msd/msd-sim/src/Physics/Constraints/ConstraintPool.hpp', is_abstract: false, is_final: false, kind: 'class', line_number: 56, name: 'ConstraintPool', qualified_name: 'msd_sim::ConstraintPool', refid: 'classmsd__sim_1_1_constraint_pool'});
CREATE (:Compound {base_classes: [], brief_description: 'Computes Lagrange multipliers for arbitrary constraint systems.', detailed_description: 'Dispatches between: Active Set Method (ASM): exact LCP, O(k^3), used when numRows <= kASMThreshold Projected Gauss-Seidel (PGS): approximate, O(n) per sweep, used for large islands Uses constraint flattening to expand multi-row constraints ( FrictionConstraint dim=2) into per-row entries for the friction system. Ticket:\\n 0031_generalized_lagrange_constraints Ticket:\\n 0052d_solver_integration_ecos_removal Ticket:\\n 0073_hybrid_pgs_large_islands', file_path: '/Users/danielnewman/dev/MSD-CPP_1/msd/msd-sim/src/Physics/Constraints/ConstraintSolver.hpp', is_abstract: false, is_final: false, kind: 'class', line_number: 52, name: 'ConstraintSolver', qualified_name: 'msd_sim::ConstraintSolver', refid: 'classmsd__sim_1_1_constraint_solver'});
CREATE (:Compound {base_classes: [], brief_description: 'Contact cache for warm-starting the constraint solver.', detailed_description: 'Maps body pairs to their previous frame\'s solved contact data (lambda values, contact normals, contact points). When contacts persist between frames, the solver starts from the previous lambda, requiring only small corrections. When contacts change significantly (normal rotation >15°), the cache is invalidated. Cache keying uses a symmetric body pair key: (min(id_A, id_B), max(id_A, id_B)) to ensure body order independence. Thread safety: Not thread-safe (single-threaded simulation) Ticket:\\n 0040d_contact_persistence_warm_starting', file_path: '/Users/danielnewman/dev/MSD-CPP_1/msd/msd-sim/src/Physics/Constraints/ContactCache.hpp', is_abstract: false, is_final: false, kind: 'class', line_number: 61, name: 'ContactCache', qualified_name: 'msd_sim::ContactCache', refid: 'classmsd__sim_1_1_contact_cache'});
CREATE (:Compound {base_classes: ['msd_sim::Constraint'], brief_description: 'Non-penetration unilateral constraint for a single contact point.', detailed_description: 'Implements the contact constraint C(q) = (x_B - x_A) · n ≥ 0 where: x_A, x_B are contact points on bodies A and B (world space) n is the contact normal (A → B, unit length) Each ContactConstraint has dimension() = 1 (one scalar constraint per contact point). A CollisionResult with contactCount = 4 produces 4 ContactConstraint instances. This follows the math formulation Section 2.5 and provides better stability for resting contacts than a centroid approximation. Design decisions: Pre-computed lever arms: r_A and r_B computed once at construction Stores pre-impact velocity: Relative normal velocity at impact time captured for restitution RHS term Baumgarte parameters: Uses Error Reduction Parameter (ERP) formulation standard in physics engines. Default: ERP = 0.2 (equivalent to α_accel ≈ 781 [1/s²] at 60 FPS). Validated by Prototype P1 parameter sweep. CRITICAL: Restitution formula uses v_target = -e · v_pre (not -(1+e)·v_pre). The constraint RHS for PGS is b = -(1+e) · J·q̇⁻, but the target velocity is -e·v_pre. See P2 Debug Findings for details. Thread safety: Immutable after construction; thread-safe for concurrent reads Error handling: Constructor validates normal is unit length, penetration >= 0, restitution in [0, 1] docs/designs/0032_contact_constraint_refactor/0032_contact_constraint_refactor.puml prototypes/0032_contact_constraint_refactor/p1_pgs_convergence/Debug_Findings.md prototypes/0032_contact_constraint_refactor/p2_energy_conservation/Debug_Findings.md Ticket:\\n 0032_contact_constraint_refactor', file_path: '/Users/danielnewman/dev/MSD-CPP_1/msd/msd-sim/src/Physics/Constraints/ContactConstraint.hpp', is_abstract: false, is_final: false, kind: 'class', line_number: 50, name: 'ContactConstraint', qualified_name: 'msd_sim::ContactConstraint', refid: 'classmsd__sim_1_1_contact_constraint'});
CREATE (:Compound {base_classes: [], brief_description: 'Represents a 3D convex hull for collision detection.', detailed_description: 'This class wraps Qhull functionality to compute convex hulls from point clouds or geometry objects. It provides the minimal data required for collision detection algorithms ( GJK , EPA , etc.). Key features: Construct from point clouds or msd_assets::Geometry objects Access to hull vertices and facets Point containment testing Support for geometric intersection operations Axis-aligned bounding box for broad-phase collision detection Note: For inertial properties (mass, centroid, moment of inertia), use AssetInertial which contains a ConvexHull along with physics properties.', file_path: '/Users/danielnewman/dev/MSD-CPP_1/msd/msd-sim/src/Physics/RigidBody/ConvexHull.hpp', is_abstract: false, is_final: false, kind: 'class', line_number: 46, name: 'ConvexHull', qualified_name: 'msd_sim::ConvexHull', refid: 'classmsd__sim_1_1_convex_hull'});
CREATE (:Compound {base_classes: [], brief_description: 'Orchestrates background recording of simulation data to SQLite database.', detailed_description: 'DataRecorder operates on a dedicated background thread, periodically flushing buffered records to disk. Record submission from the simulation thread is thread-safe via cpp_sqlite\'s double-buffered DAOs. Architecture: Simulation thread calls recordFrame() to create timestamped frames Simulation thread calls getDAO<T>() .addToBuffer(record) for per-frame data Recorder thread wakes periodically to flush all buffers via transaction Destructor ensures all pending records are written before shutdown docs/designs/0038_simulation_data_recorder/0038_simulation_data_recorder.puml Ticket:\\n 0038_simulation_data_recorder', file_path: '/Users/danielnewman/dev/MSD-CPP_1/msd/msd-sim/src/DataRecorder/DataRecorder.hpp', is_abstract: false, is_final: false, kind: 'class', line_number: 58, name: 'DataRecorder', qualified_name: 'msd_sim::DataRecorder', refid: 'classmsd__sim_1_1_data_recorder'});
CREATE (:Compound {base_classes: ['msd_transfer::ConstraintRecordVisitor'], brief_description: 'Concrete visitor that buffers constraint records to DataRecorder DAOs.', detailed_description: 'Implements the ConstraintRecordVisitor interface to enable type-safe constraint state recording without dynamic_cast or std::any_cast. Each visit() method receives a typed constraint record, sets the frame FK, and buffers it to the appropriate DAO. Usage: DataRecorderVisitor visitor{recorder, frameId}; constraint->recordState(visitor, bodyAId, bodyBId); // Dispatches to appropriate visit() Thread safety: Not thread-safe (caller must ensure DataRecorder thread safety) Error handling: Exceptions from DAO operations propagate to caller msd_transfer::ConstraintRecordVisitor DataRecorder', file_path: '/Users/danielnewman/dev/MSD-CPP_1/msd/msd-sim/src/DataRecorder/DataRecorderVisitor.hpp', is_abstract: false, is_final: false, kind: 'class', line_number: 32, name: 'DataRecorderVisitor', qualified_name: 'msd_sim::DataRecorderVisitor', refid: 'classmsd__sim_1_1_data_recorder_visitor'});
CREATE (:Compound {base_classes: ['msd_sim::Constraint'], brief_description: 'Fixed distance constraint from origin (single-object example).', detailed_description: 'Maintains the constraint C(X) = |X|² - d² = 0 to keep an object at a fixed distance d from the origin. This is a simplified single-object constraint demonstrating the constraint framework. Multi-object distance constraints (between two objects) are deferred to future ticket 0032. Mathematical formulation: Constraint : C(X) = |X|² - d² = 0 (scalar constraint) Jacobian: J = 2·X^T (1×3 row vector w.r.t. position components) Time derivative: ∂C/∂t = 0 (time-independent) Use cases: Orbital mechanics: fixed orbital radius Pendulum: fixed rod length Tethered objects: cable length constraint Thread safety: Thread-safe for concurrent evaluation after construction Error handling: Throws std::invalid_argument if targetDistance <= 0 docs/designs/0043_constraint_hierarchy_refactor/0043_constraint_hierarchy_refactor.puml Ticket:\\n 0043_constraint_hierarchy_refactor', file_path: '/Users/danielnewman/dev/MSD-CPP_1/msd/msd-sim/src/Physics/Constraints/DistanceConstraint.hpp', is_abstract: false, is_final: false, kind: 'class', line_number: 37, name: 'DistanceConstraint', qualified_name: 'msd_sim::DistanceConstraint', refid: 'classmsd__sim_1_1_distance_constraint'});
CREATE (:Compound {base_classes: [], brief_description: 'Expanding Polytope Algorithm ( EPA ) for contact information extraction.', detailed_description: 'EPA computes penetration depth, contact normal, and contact point from a GJK terminating simplex. When GJK detects an intersection, EPA expands the terminating simplex (tetrahedron containing the origin) into a polytope until the closest face to the origin is found, yielding complete collision data. Algorithm steps: Initialize polytope from GJK simplex (4 vertices, 4 triangular faces) Find closest face to origin Query support point in direction of face normal If new point within tolerance, found closest face → terminate Else, remove visible faces, build horizon edges, add new faces Repeat until convergence Contact extraction: Contact normal = closest face normal (normalized, A→B) Penetration depth = distance from origin to closest face Contact point = barycentric centroid of closest face docs/designs/0027a_expanding_polytope_algorithm/0027a_expanding_polytope_algorithm.puml Ticket:\\n 0027a_expanding_polytope_algorithm', file_path: '/Users/danielnewman/dev/MSD-CPP_1/msd/msd-sim/src/Physics/Collision/EPA.hpp', is_abstract: false, is_final: false, kind: 'class', line_number: 66, name: 'EPA', qualified_name: 'msd_sim::EPA', refid: 'classmsd__sim_1_1_e_p_a'});
CREATE (:Compound {base_classes: [], brief_description: 'Energy computation utility for rigid body diagnostics.', detailed_description: 'Provides static methods to compute kinetic and potential energy for individual bodies and the entire system. Used by WorldModel to record energy data for collision debugging and anomaly detection. CRITICAL: Rotational kinetic energy uses world-frame inertia tensor: KE_rot = 0.5 * omega^T * I_world * omega where I_world = R * I_body * R^T Using body-frame inertia with world-frame angular velocity produces chaotic-looking energy even when physics are correct. Ticket:\\n 0039a_energy_tracking_diagnostic_infrastructure', file_path: '/Users/danielnewman/dev/MSD-CPP_1/msd/msd-sim/src/Diagnostics/EnergyTracker.hpp', is_abstract: false, is_final: false, kind: 'class', line_number: 37, name: 'EnergyTracker', qualified_name: 'msd_sim::EnergyTracker', refid: 'classmsd__sim_1_1_energy_tracker'});
CREATE (:Compound {base_classes: [], brief_description: 'Top-level simulation orchestrator.', detailed_description: 'Coordinates asset loading (via AssetRegistry), world management (via WorldModel ), and physics simulation updates. Provides the primary entry point for spawning objects into the simulation and stepping time forward. Also exposed to Python as msd_reader.Engine via the pybind11 EngineWrapper (see msd-pybind/src/engine_bindings.cpp ). Not thread-safe — single-threaded simulation assumed.', file_path: '/Users/danielnewman/dev/MSD-CPP_1/msd/msd-sim/src/Engine.hpp', is_abstract: false, is_final: false, kind: 'class', line_number: 29, name: 'Engine', qualified_name: 'msd_sim::Engine', refid: 'classmsd__sim_1_1_engine'});
CREATE (:Compound {base_classes: ['msd_sim::Constraint'], brief_description: 'Friction constraint for two-body contact (two tangential constraint rows).', detailed_description: 'Implements tangential friction constraints for a contact point using two orthogonal tangent directions. Each FrictionConstraint has dimension() = 2 (one row per tangent). Constraint formulation: C_t1(q) = relative tangential velocity in t1 direction C_t2(q) = relative tangential velocity in t2 direction Jacobian J_ti = [ti^T, (rA×ti)^T, -ti^T, -(rB×ti)^T] ∈ R^(1×12) Box constraints (Coulomb cone projection): -μ/√2 · λn ≤ λt1 ≤ μ/√2 · λn -μ/√2 · λn ≤ λt2 ≤ μ/√2 · λn √2 factor distributes circular cone into two orthogonal box constraints Design notes: Tangent basis computed once at construction via TangentBasis::computeTangentBasis() Friction coefficient μ stored (combined from materials, computed externally) Normal force λn updated each solver iteration via setNormalLambda() Follows same 12-DOF Jacobian structure as ContactConstraint (direct angular velocity) Mathematical formulation: docs/designs/0035_friction_constraints/M2-friction-jacobian.md Thread safety: Immutable after construction except setNormalLambda() (not thread-safe) Error handling: Constructor validates normal unit length, mu in [0, ∞) Constraint ContactConstraint docs/designs/0035a_tangent_basis_and_friction_constraint/0035a_tangent_basis_and_friction_constraint.puml Ticket:\\n 0035a_tangent_basis_and_friction_constraint', file_path: '/Users/danielnewman/dev/MSD-CPP_1/msd/msd-sim/src/Physics/Constraints/FrictionConstraint.hpp', is_abstract: false, is_final: false, kind: 'class', line_number: 58, name: 'FrictionConstraint', qualified_name: 'msd_sim::FrictionConstraint', refid: 'classmsd__sim_1_1_friction_constraint'});
CREATE (:Compound {base_classes: [], brief_description: 'GJK (Gilbert-Johnson-Keerthi) collision detection algorithm.', detailed_description: 'The GJK algorithm efficiently detects collision between convex shapes by iteratively constructing a simplex in Minkowski difference space that attempts to contain the origin. https://computerwebsite.net/writing/gjk Key insight: Two convex shapes A and B intersect if and only if their Minkowski difference (A ⊖ B) contains the origin. This class maintains the algorithm state (simplex and search direction) as it iterates toward a solution. It works with AssetPhysical objects to support collision detection between objects with arbitrary world-space transformations. docs/designs/0022_gjk_asset_physical_transform/0022_gjk_asset_physical_transform.puml Ticket:\\n 0022_gjk_asset_physical_transform', file_path: '/Users/danielnewman/dev/MSD-CPP_1/msd/msd-sim/src/Physics/Collision/GJK.hpp', is_abstract: false, is_final: false, kind: 'class', line_number: 36, name: 'GJK', qualified_name: 'msd_sim::GJK', refid: 'classmsd__sim_1_1_g_j_k'});
CREATE (:Compound {base_classes: ['msd_sim::PotentialEnergy'], brief_description: 'Uniform gravitational field potential energy.', detailed_description: 'Implements V = m * g * z where z is the vertical position component. The gravitational vector g is typically (0, 0, -9.81) in z-up convention. Uniform gravity produces constant force F = m*g but no torque (orientation-independent). docs/designs/0030_lagrangian_quaternion_physics/0030_lagrangian_quaternion_physics.puml Ticket:\\n 0030_lagrangian_quaternion_physics', file_path: '/Users/danielnewman/dev/MSD-CPP_1/msd/msd-sim/src/Physics/PotentialEnergy/GravityPotential.hpp', is_abstract: false, is_final: false, kind: 'class', line_number: 23, name: 'GravityPotential', qualified_name: 'msd_sim::GravityPotential', refid: 'classmsd__sim_1_1_gravity_potential'});
CREATE (:Compound {base_classes: ['msd_sim::BaseAgent'], brief_description: 'Agent implementation that translates InputCommands into InertialState updates.', detailed_description: 'Implements the BaseAgent interface to fit cleanly into the simulation architecture. Separates input commands from state update logic. Usage flow: GUI calls setInputCommands() with current input state Engine calls updateState() during simulation update Agent translates boolean commands into velocity/acceleration Thread safety: Not thread-safe', file_path: '/Users/danielnewman/dev/MSD-CPP_1/msd/msd-sim/src/Agent/InputControlAgent.hpp', is_abstract: false, is_final: false, kind: 'class', line_number: 29, name: 'InputControlAgent', qualified_name: 'msd_sim::InputControlAgent', refid: 'classmsd__sim_1_1_input_control_agent'});
CREATE (:Compound {base_classes: [], brief_description: 'Abstract interface for numerical integration of rigid body dynamics.', detailed_description: 'Decouples the integration scheme from the physics computation, enabling: Swappable integrators (Euler, RK4, Verlet, etc.) Isolated testing of integration math WorldModel as pure orchestrator Ticket 0031 breaking change: Replaced QuaternionConstraint & with std::vector<Constraint*>& to support arbitrary constraint combinations. Thread safety: Implementations should be stateless and thread-safe docs/designs/0030_lagrangian_quaternion_physics/0030_lagrangian_quaternion_physics.puml docs/designs/0031_generalized_lagrange_constraints/0031_generalized_lagrange_constraints.puml Ticket:\\n 0030_lagrangian_quaternion_physics Ticket:\\n 0031_generalized_lagrange_constraints', file_path: '/Users/danielnewman/dev/MSD-CPP_1/msd/msd-sim/src/Physics/Integration/Integrator.hpp', is_abstract: true, is_final: false, kind: 'class', line_number: 39, name: 'Integrator', qualified_name: 'msd_sim::Integrator', refid: 'classmsd__sim_1_1_integrator'});
CREATE (:Compound {base_classes: [], brief_description: 'Encapsulates 3D motion control logic for simulation objects.', detailed_description: 'Translates input commands into ReferenceFrame updates (translation and rotation). Replaces msd-gui::CameraController with simulation-appropriate implementation. Supports frame-rate independent movement through delta-time scaling. Movement is applied in the local coordinate frame of the provided ReferenceFrame . docs/designs/0005_camera_controller_sim/0005_camera_controller_sim.puml Ticket:\\n 0005_camera_controller_sim Thread safety: Not thread-safe (modifies ReferenceFrame in place)', file_path: '/Users/danielnewman/dev/MSD-CPP_1/msd/msd-sim/src/Environment/MotionController.hpp', is_abstract: false, is_final: false, kind: 'class', line_number: 31, name: 'MotionController', qualified_name: 'msd_sim::MotionController', refid: 'classmsd__sim_1_1_motion_controller'});
CREATE (:Compound {base_classes: [], brief_description: 'NLopt-based solver for the friction cone constrained QP.', detailed_description: 'Solves: minimize f(lambda) = (1/2) lambda^T A lambda - b^T lambda subject to mu_i^2 * lambda_n_i^2 - lambda_t1_i^2 - lambda_t2_i^2 >= 0 (cone constraint) lambda_n_i >= 0 (non-penetration) Uses NLopt\'s SLSQP (Sequential Quadratic Programming) by default for efficient handling of quadratic objectives with nonlinear constraints. Supports warm-starting from previous frame\'s solution via ContactCache . docs/designs/0068_nlopt_friction_cone_solver/0068_nlopt_friction_cone_solver.puml Ticket:\\n 0068b_nlopt_friction_solver_class', file_path: '/Users/danielnewman/dev/MSD-CPP_1/msd/msd-sim/src/Physics/Constraints/NLoptFrictionSolver.hpp', is_abstract: false, is_final: false, kind: 'class', line_number: 29, name: 'NLoptFrictionSolver', qualified_name: 'msd_sim::NLoptFrictionSolver', refid: 'classmsd__sim_1_1_n_lopt_friction_solver'});
CREATE (:Compound {base_classes: [], brief_description: 'Platform entity with kinematic state and agent control.', detailed_description: 'Platform owns an agent that controls its state and optionally links to an Object in WorldModel for visual representation synchronization. Per AC7: Agent logic is placed in Platform (not Object) Per AC3: Each Platform has its own non-unique internal state Thread safety: Not thread-safe', file_path: '/Users/danielnewman/dev/MSD-CPP_1/msd/msd-sim/src/Environment/Platform.hpp', is_abstract: false, is_final: false, kind: 'class', line_number: 35, name: 'Platform', qualified_name: 'msd_sim::Platform', refid: 'classmsd__sim_1_1_platform'});
CREATE (:Compound {base_classes: [], brief_description: 'Position-level contact correction using pseudo-velocities.', detailed_description: 'Corrects penetration depth by computing position-level impulses that modify body positions and orientations without affecting real velocities. This is the position correction pass of the split impulse approach. Algorithm: For each contact, compute position-level bias: b_pos = (beta/dt) * max(depth - slop, 0) Build effective mass matrix A = J * M^-1 * J^T Solve A * lambda_pos = b_pos with lambda_pos >= 0 (using ASM) Compute pseudo-velocity: dv_pseudo = M^-1 * J^T * lambda_pos Apply as position change: dx = dv_pseudo * dt Discard pseudo-velocity (never becomes kinetic energy) Ticket:\\n 0040b_split_impulse_position_correction', file_path: '/Users/danielnewman/dev/MSD-CPP_1/msd/msd-sim/src/Physics/Constraints/PositionCorrector.hpp', is_abstract: false, is_final: false, kind: 'class', line_number: 34, name: 'PositionCorrector', qualified_name: 'msd_sim::PositionCorrector', refid: 'classmsd__sim_1_1_position_corrector'});
CREATE (:Compound {base_classes: [], brief_description: 'Abstract interface for environmental potential energy fields.', detailed_description: 'This interface enables extensible potential energy computation for rigid body dynamics. Implementations compute generalized forces from energy gradients. Lagrangian formulation: L = T - V where T is kinetic energy, V is potential energy Generalized forces: F = -∂V/∂X (linear force from position gradient) τ = -∂V/∂Q (torque from orientation gradient) Note: These are ENVIRONMENTAL potentials (gravity, magnetic fields) that apply uniformly to all objects. Per-object forces (thrusters, springs) would be handled separately in AssetInertial . Thread safety: Read-only methods after construction (thread-safe) docs/designs/0030_lagrangian_quaternion_physics/0030_lagrangian_quaternion_physics.puml Ticket:\\n 0030_lagrangian_quaternion_physics', file_path: '/Users/danielnewman/dev/MSD-CPP_1/msd/msd-sim/src/Physics/PotentialEnergy/PotentialEnergy.hpp', is_abstract: true, is_final: false, kind: 'class', line_number: 34, name: 'PotentialEnergy', qualified_name: 'msd_sim::PotentialEnergy', refid: 'classmsd__sim_1_1_potential_energy'});
CREATE (:Compound {base_classes: [], brief_description: 'O(n)-per-sweep iterative LCP solver using Projected Gauss-Seidel.', detailed_description: 'Used by ConstraintSolver as the solver backend for large constraint islands (numRows > kASMThreshold). PGS has O(n) cost per sweep and scales linearly with problem size, making it ~40x cheaper per sweep than a single ASM pivot at 160 constraints. Algorithm (Catto 2005): For each sweep, for each constraint row i: delta_i = (b_i - J_i * v_res) / A_ii using velocity-residual approach For normal rows: lambda_i = max(0, lambda_i + delta_i) For friction rows: solve both tangent components, then ball-project the 2D tangent vector onto the friction disk ||lambda_t|| <= mu * lambda_n Velocity-residual approach (O(n) workspace): v_res (6 * numBodies doubles) accumulates M^{-1} * J^T * lambda After each lambda update: v_res += M^{-1} * J_i^T * delta_lambda_i Off-diagonal contribution for row i: J_i * v_res Friction coupling (R1 from design review): PGS applies ball-projection directly on friction rows, bypassing FrictionConstraint::lambdaBounds() . The ball-projection cone (||lambda_t|| <= mu*lambda_n) is consistent with the decoupled solver from ticket 0070. setNormalLambda() is NOT called during PGS sweeps. docs/designs/0073_hybrid_pgs_large_islands/design.md Ticket:\\n 0073_hybrid_pgs_large_islands', file_path: '/Users/danielnewman/dev/MSD-CPP_1/msd/msd-sim/src/Physics/Constraints/ProjectedGaussSeidel.hpp', is_abstract: false, is_final: false, kind: 'class', line_number: 57, name: 'ProjectedGaussSeidel', qualified_name: 'msd_sim::ProjectedGaussSeidel', refid: 'classmsd__sim_1_1_projected_gauss_seidel'});
CREATE (:Compound {base_classes: [], brief_description: 'Enforces unit quaternion constraint via Lagrange multipliers.', detailed_description: 'Maintains the constraint g(Q) = QᵀQ - 1 = 0 using Baumgarte stabilization to correct drift accumulated during numerical integration. Constraint equations: Position: g(Q) = QᵀQ - 1 = 0 Velocity : ġ = 2QᵀQ̇ = 0 (Q̇ ⊥ Q) Baumgarte stabilization computes Lagrange multiplier as: λ = -α * g - β * ġ where α, β > 0 are tuning parameters. Ownership: Each AssetInertial owns its own QuaternionConstraint instance, since the constraint operates on per-object quaternion state. Thread safety: Not thread-safe (modifies quaternion state) docs/designs/0030_lagrangian_quaternion_physics/0030_lagrangian_quaternion_physics.puml Ticket:\\n 0030_lagrangian_quaternion_physics', file_path: '/Users/danielnewman/dev/MSD-CPP_1/msd/msd-sim/src/Physics/Constraints/QuaternionConstraint.hpp', is_abstract: false, is_final: false, kind: 'class', line_number: 34, name: 'QuaternionConstraint', qualified_name: 'msd_sim::QuaternionConstraint', refid: 'classmsd__sim_1_1_quaternion_constraint'});
CREATE (:Compound {base_classes: [], brief_description: 'A reference frame for coordinate transformations.', detailed_description: 'This class represents a reference frame that can be translated and rotated relative to a global frame. It uses AngularCoordinate (pitch, roll, yaw) for rotation specification and provides methods to transform coordinates between the global frame and the local frame. Rotation order: ZYX (yaw-pitch-roll) intrinsic rotations Roll: rotation around X-axis (component 1) Pitch: rotation around Y-axis (component 0) Yaw: rotation around Z-axis (component 2) docs/designs/0024_angular_coordinate/0024_angular_coordinate.puml Ticket:\\n 0024_angular_coordinate', file_path: '/Users/danielnewman/dev/MSD-CPP_1/msd/msd-sim/src/Environment/ReferenceFrame.hpp', is_abstract: false, is_final: false, kind: 'class', line_number: 54, name: 'ReferenceFrame', qualified_name: 'msd_sim::ReferenceFrame', refid: 'classmsd__sim_1_1_reference_frame'});
CREATE (:Compound {base_classes: ['msd_sim::Integrator'], brief_description: 'Semi-implicit Euler integrator (symplectic).', detailed_description: 'Integration order: Compute accelerations: a = F_ext / m, α = I^-1 * τ_ext Update velocities: v_new = v_old + a * dt Update positions: x_new = x_old + v_new * dt (uses NEW velocity) Integrate quaternion: Q_new = Q_old + Q̇ * dt Normalize quaternion (position-level drift correction) Properties: First-order accurate Symplectic (preserves phase space volume) Better energy conservation than explicit Euler Ticket 0045 breaking change: Removed constraint solving from integrator. Quaternion normalization is now handled via state.orientation.normalize() instead of UnitQuaternionConstraint . docs/designs/0030_lagrangian_quaternion_physics/0030_lagrangian_quaternion_physics.puml docs/designs/0045_constraint_solver_unification/design.md Ticket:\\n 0030_lagrangian_quaternion_physics Ticket:\\n 0045_constraint_solver_unification', file_path: '/Users/danielnewman/dev/MSD-CPP_1/msd/msd-sim/src/Physics/Integration/SemiImplicitEulerIntegrator.hpp', is_abstract: false, is_final: false, kind: 'class', line_number: 40, name: 'SemiImplicitEulerIntegrator', qualified_name: 'msd_sim::SemiImplicitEulerIntegrator', refid: 'classmsd__sim_1_1_semi_implicit_euler_integrator'});
CREATE (:Compound {base_classes: ['msd_sim::Constraint'], brief_description: 'Unit quaternion normalization constraint using Lagrange multipliers.', detailed_description: 'Maintains the constraint g(Q) = Q^T·Q - 1 = 0 to ensure quaternion remains normalized during numerical integration. This is a drop-in replacement for the deprecated QuaternionConstraint , reimplemented using the generalized constraint framework. Mathematical formulation: Constraint : C(Q) = Q^T·Q - 1 = 0 (scalar constraint) Jacobian: J = 2·Q^T (1×4 row vector w.r.t. quaternion components) Time derivative: ∂C/∂t = 0 (time-independent) Baumgarte stabilization: Position term: α·(Q^T·Q - 1) Velocity term: β·(2·Q^T·Q̇) Default parameters: α = 10.0, β = 10.0 (validated for dt ~ 0.016s) Thread safety: Thread-safe for concurrent evaluation after construction Error handling: No exceptions (all quaternion operations numerically stable) docs/designs/0043_constraint_hierarchy_refactor/0043_constraint_hierarchy_refactor.puml Ticket:\\n 0043_constraint_hierarchy_refactor', file_path: '/Users/danielnewman/dev/MSD-CPP_1/msd/msd-sim/src/Physics/Constraints/UnitQuaternionConstraint.hpp', is_abstract: false, is_final: false, kind: 'class', line_number: 36, name: 'UnitQuaternionConstraint', qualified_name: 'msd_sim::UnitQuaternionConstraint', refid: 'classmsd__sim_1_1_unit_quaternion_constraint'});
CREATE (:Compound {base_classes: [], brief_description: 'Container and manager for all simulation objects.', detailed_description: 'WorldModel uses a unified storage approach with index-based iteration for efficient physics updates and collision detection. The WorldModel maintains: A single vector of all objects (graphical, inertial, environmental, boundary) Cached index lists for efficient iteration over specific object types Current simulation time Efficient iteration patterns: // Physics update - only iterate objects with physics for ( size_t idx : worldModel.getPhysicsObjectIndices()) { Object& obj = worldModel.getObject(idx); // Update physics... } // Collision detection - only iterate objects with collision hulls for ( size_t idx : worldModel.getCollisionObjectIndices()) { // Check collisions... } // Rendering - only iterate objects with visual geometry for ( size_t idx : worldModel.getRenderObjectIndices()) { // Render... }', file_path: '/Users/danielnewman/dev/MSD-CPP_1/msd/msd-sim/src/Environment/WorldModel.hpp', is_abstract: false, is_final: false, kind: 'class', line_number: 52, name: 'WorldModel', qualified_name: 'msd_sim::WorldModel', refid: 'classmsd__sim_1_1_world_model'});
CREATE (:Compound {base_classes: [], brief_description: 'CRTP base class for quaternion types.', detailed_description: 'Wraps Eigen::Quaterniond via composition (not inheritance, since Eigen::Quaterniond is not a matrix type). Uses Eigen/Hamilton convention: q = w + xi + yj + zk Derived The derived type (CRTP pattern)', file_path: '/Users/danielnewman/dev/MSD-CPP_1/msd/msd-sim/src/DataTypes/QuatDBase.hpp', is_abstract: false, is_final: false, kind: 'class', line_number: 25, name: 'QuatDBase', qualified_name: 'msd_sim::detail::QuatDBase', refid: 'classmsd__sim_1_1detail_1_1_quat_d_base'});
CREATE (:Compound {base_classes: ['Eigen::Vector3d'], brief_description: 'CRTP base class for 3D vector types.', detailed_description: 'Provides common functionality for all 3D vector types by inheriting from Eigen::Vector3d. Derived types should use this as: struct MyVec3Type final : Vec3DBase<MyVec3Type> { ... }; Derived The derived type (CRTP pattern)', file_path: '/Users/danielnewman/dev/MSD-CPP_1/msd/msd-sim/src/DataTypes/Vec3DBase.hpp', is_abstract: false, is_final: false, kind: 'class', line_number: 25, name: 'Vec3DBase', qualified_name: 'msd_sim::detail::Vec3DBase', refid: 'classmsd__sim_1_1detail_1_1_vec3_d_base'});
CREATE (:Compound {base_classes: ['Eigen::Vector4d'], brief_description: 'CRTP base class for 4D vector types.', detailed_description: 'Provides common functionality for all 4D vector types by inheriting from Eigen::Vector4d. Derived types should use this as: struct MyVec4Type final : Vec4DBase<MyVec4Type> { ... }; Derived The derived type (CRTP pattern)', file_path: '/Users/danielnewman/dev/MSD-CPP_1/msd/msd-sim/src/DataTypes/Vec4DBase.hpp', is_abstract: false, is_final: false, kind: 'class', line_number: 25, name: 'Vec4DBase', qualified_name: 'msd_sim::detail::Vec4DBase', refid: 'classmsd__sim_1_1detail_1_1_vec4_d_base'});
CREATE (:Compound {base_classes: [], brief_description: 'Visitor interface for type-safe constraint record dispatching.', detailed_description: 'This interface enables polymorphic constraint recording without dynamic_cast or std::any. Each concrete constraint type calls the appropriate visit() overload, and the compiler enforces that all constraint types are handled. To add a new constraint type: Add new visit(const NewConstraintRecord&) overload to this interface Implement the overload in all concrete visitors (e.g., DataRecorderVisitor) The constraint calls visitor.visit(record) in its recordState() method Compiler will catch missing visit() implementations at build time.', file_path: '/Users/danielnewman/dev/MSD-CPP_1/msd/msd-transfer/src/ConstraintRecordVisitor.hpp', is_abstract: true, is_final: false, kind: 'class', line_number: 23, name: 'ConstraintRecordVisitor', qualified_name: 'msd_transfer::ConstraintRecordVisitor', refid: 'classmsd__transfer_1_1_constraint_record_visitor'});
