CREATE (:Compound {base_classes: ['cpp_sqlite::BaseTransferObject'], brief_description: 'Database record for a quaternion (double precision).', detailed_description: 'Stores the w, x, y, z components of an msd_sim::QuaternionD as individual scalar doubles for human-readable database inspection and queryability. Uses Eigen/Hamilton convention: q = w + xi + yj + zk where w is the scalar (real) part and (x, y, z) is the vector (imaginary) part.', file_path: '/Users/danielnewman/dev/MSD-CPP_1/msd/msd-transfer/src/QuaternionDRecord.hpp', is_abstract: false, is_final: false, kind: 'struct', line_number: 21, name: 'QuaternionDRecord', qualified_name: 'msd_transfer::QuaternionDRecord', refid: 'structmsd__transfer_1_1_quaternion_d_record'});
CREATE (:Compound {base_classes: ['cpp_sqlite::BaseTransferObject'], brief_description: 'Database record for simulation frame timestamping.', detailed_description: 'Each simulation frame has exactly one SimulationFrameRecord . Per-frame records ( InertialStateRecord , etc.) reference this frame via ForeignKey<SimulationFrameRecord> for temporal association. The id field is inherited from BaseTransferObject and serves as the primary key for frame identification. docs/designs/0038_simulation_data_recorder/0038_simulation_data_recorder.puml Ticket:\\n 0038_simulation_data_recorder', file_path: '/Users/danielnewman/dev/MSD-CPP_1/msd/msd-transfer/src/SimulationFrameRecord.hpp', is_abstract: false, is_final: false, kind: 'struct', line_number: 26, name: 'SimulationFrameRecord', qualified_name: 'msd_transfer::SimulationFrameRecord', refid: 'structmsd__transfer_1_1_simulation_frame_record'});
CREATE (:Compound {base_classes: ['cpp_sqlite::BaseTransferObject'], brief_description: 'Per-frame solver diagnostics.', detailed_description: 'Records constraint solver statistics for debugging convergence issues and analyzing solver performance. Ticket:\\n 0056a_collision_force_transfer_records', file_path: '/Users/danielnewman/dev/MSD-CPP_1/msd/msd-transfer/src/SolverDiagnosticRecord.hpp', is_abstract: false, is_final: false, kind: 'struct', line_number: 25, name: 'SolverDiagnosticRecord', qualified_name: 'msd_transfer::SolverDiagnosticRecord', refid: 'structmsd__transfer_1_1_solver_diagnostic_record'});
CREATE (:Compound {base_classes: ['cpp_sqlite::BaseTransferObject'], brief_description: 'Database record for system-level energy summary.', detailed_description: 'Stores aggregated energy values across all rigid bodies for a given simulation frame. Includes energy change detection for anomaly identification during collision debugging. Fields: total_linear_ke: Sum of all body linear kinetic energies [J] total_rotational_ke: Sum of all body rotational kinetic energies [J] total_potential_e: Sum of all body potential energies [J] total_system_e: Total system mechanical energy [J] delta_e: Energy change from previous frame [J] energy_injection: 1 if delta_e exceeds tolerance (anomaly flag) collision_active: 1 if any collision detected this frame energy_injection and collision_active use uint32_t for SQLite compatibility (SQLite has no native boolean type). msd_sim::EnergyTracker Ticket:\\n 0039a_energy_tracking_diagnostic_infrastructure', file_path: '/Users/danielnewman/dev/MSD-CPP_1/msd/msd-transfer/src/SystemEnergyRecord.hpp', is_abstract: false, is_final: false, kind: 'struct', line_number: 37, name: 'SystemEnergyRecord', qualified_name: 'msd_transfer::SystemEnergyRecord', refid: 'structmsd__transfer_1_1_system_energy_record'});
