CREATE (:Member {argsstring: '(const std::vector< Constraint * > &constraints, size_t numInertialBodies)', brief_description: 'Partition constraints into independent contact islands.', compound_refid: 'classmsd__sim_1_1_constraint_island_builder', definition: 'std::vector< ConstraintIslandBuilder::Island > msd_sim::ConstraintIslandBuilder::buildIslands', detailed_description: 'Implements union-find over inertial body indices to determine connected components. Environment bodies (index >= numInertialBodies) do NOT create connectivity between inertial bodies — two cubes touching the same floor form two separate islands because the floor has infinite mass and cannot transmit impulses between them. The constraint ordering within each island preserves the relative order from the input list, which maintains the CC-before-paired-FC interleaving required by ConstraintSolver . constraints All constraints for the current frame (non-owning pointers) numInertialBodies Number of inertial (dynamic) bodies. Environment body indices satisfy: bodyIndex >= numInertialBodies. List of independent islands. Each island contains its constraint subset and all unique body indices (including environment indices) referenced by those constraints. Returns empty vector if constraints is empty.', file_path: '/Users/danielnewman/dev/MSD-CPP_1/msd/msd-sim/src/Physics/Constraints/ConstraintIslandBuilder.hpp', is_const: false, is_constexpr: false, is_explicit: false, is_inline: false, is_static: true, is_virtual: false, kind: 'function', line_number: 78, name: 'buildIslands', protection: 'public', qualified_name: 'msd_sim::ConstraintIslandBuilder::buildIslands', refid: 'classmsd__sim_1_1_constraint_island_builder_1a98aab8ad053ebef40dad05247680a505', type: 'std::vector< Island >'});
