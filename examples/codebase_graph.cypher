CREATE (:Member {argsstring: '(msd_transfer::ConstraintRecordVisitor &visitor, uint32_t bodyAId, uint32_t bodyBId) const override', brief_description: 'Record constraint state via visitor pattern.', compound_refid: 'classmsd__sim_1_1_distance_constraint', definition: 'void msd_sim::DistanceConstraint::recordState', detailed_description: 'Builds a typed constraint record (ContactConstraintRecord, FrictionConstraintRecord, etc.) and dispatches to the visitor via overload resolution. The visitor decides what to do with the record (e.g., buffer to DataRecorder DAO). Enables compile-time type-safe constraint recording without dynamic_cast or std::any_cast. New constraint types extend ConstraintRecordVisitor with a new visit() overload. visitor Visitor that processes the typed constraint record bodyAId Persistent ID of body A for database FK reference bodyBId Persistent ID of body B for database FK reference (ignored for single-body) msd_transfer::ConstraintRecordVisitor msd_sim::DataRecorderVisitor', file_path: '/Users/danielnewman/dev/MSD-CPP_1/msd/msd-sim/src/Physics/Constraints/DistanceConstraint.hpp', is_const: true, is_constexpr: false, is_explicit: false, is_inline: false, is_static: false, is_virtual: true, kind: 'function', line_number: 72, name: 'recordState', protection: 'public', qualified_name: 'msd_sim::DistanceConstraint::recordState', refid: 'classmsd__sim_1_1_distance_constraint_1a77c1b8063f1bd2abb0724ea8e5fe518d', type: 'void'});
