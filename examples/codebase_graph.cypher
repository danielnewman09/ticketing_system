CREATE (:Member {argsstring: '(const AssetPhysical &assetA, const AssetPhysical &assetB, bool skipSATValidation=false) const', brief_description: 'Check for collision between two physical assets.', compound_refid: 'classmsd__sim_1_1_collision_handler', definition: 'std::optional< CollisionResult > msd_sim::CollisionHandler::checkCollision', detailed_description: 'Runs GJK to detect intersection. If collision detected, runs EPA to compute penetration depth, contact normal, and contact point. assetA First physical asset assetB Second physical asset skipSATValidation If true, skip SAT validation of EPA result. Use when ContactCache confirms persistent contact with stable normal, making EPA failure unlikely. Ticket: 0053d_sat_fallback_cost_reduction std::nullopt if no collision, CollisionResult if collision', file_path: '/Users/danielnewman/dev/MSD-CPP_1/msd/msd-sim/src/Physics/Collision/CollisionHandler.hpp', is_const: true, is_constexpr: false, is_explicit: false, is_inline: false, is_static: false, is_virtual: false, kind: 'function', line_number: 56, name: 'checkCollision', protection: 'public', qualified_name: 'msd_sim::CollisionHandler::checkCollision', refid: 'classmsd__sim_1_1_collision_handler_1af8b884cb1ae586fd96b61a99df59f943', type: 'std::optional< CollisionResult >'});
CREATE (:Member {argsstring: '(class DataRecorder &recorder, uint32_t frameId) const', brief_description: 'Record constraint states to DataRecorder .', compound_refid: 'classmsd__sim_1_1_collision_pipeline', definition: 'void msd_sim::CollisionPipeline::recordConstraints', detailed_description: 'Iterates all constraints (both ContactConstraint and FrictionConstraint ), calls constraint->recordState() with a DataRecorderVisitor , and buffers the typed records to the appropriate DAOs. Uses visitor pattern for type-safe dispatching without dynamic_cast. Each constraint builds its specific record (ContactConstraintRecord or FrictionConstraintRecord) and dispatches to visitor.visit(record). Must be called AFTER execute() and BEFORE clearEphemeralState() to ensure constraints are still alive. recorder DataRecorder instance to buffer records to frameId Frame ID for FK references in constraint records Thread safety: Not thread-safe (calls DataRecorder methods) Error handling: Exceptions from DAO operations propagate to caller DataRecorderVisitor Constraint::recordState() Ticket:\\n 0057_contact_tangent_recording', file_path: '/Users/danielnewman/dev/MSD-CPP_1/msd/msd-sim/src/Physics/Collision/CollisionPipeline.hpp', is_const: true, is_constexpr: false, is_explicit: false, is_inline: false, is_static: false, is_virtual: false, kind: 'function', line_number: 216, name: 'recordConstraints', protection: 'public', qualified_name: 'msd_sim::CollisionPipeline::recordConstraints', refid: 'classmsd__sim_1_1_collision_pipeline_1a00bec9674b4999c9929bf5f4d44efac0', type: 'void'});
