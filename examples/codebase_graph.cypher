CREATE (:Member {argsstring: '(const std::vector< double > &lambda, std::vector< double > &grad, void *data)', brief_description: 'Cone constraint callback for contact i: c_i(lambda) = mu^2*n^2 - t1^2 - t2^2.', compound_refid: 'classmsd__sim_1_1_n_lopt_friction_solver', definition: 'double msd_sim::NLoptFrictionSolver::coneConstraint', detailed_description: 'Note: NLopt expects constraints as c(x) <= 0, so we negate to -c(x) <= 0 which is equivalent to c(x) >= 0. lambda Current iterate (3C x 1) grad Output gradient (3 x 1): [2*mu^2*n, -2*t1, -2*t2] data Pointer to ConstraintData struct Constraint value (negated for NLopt convention)', file_path: '/Users/danielnewman/dev/MSD-CPP_1/msd/msd-sim/src/Physics/Constraints/NLoptFrictionSolver.hpp', is_const: false, is_constexpr: false, is_explicit: false, is_inline: false, is_static: true, is_virtual: false, kind: 'function', line_number: 138, name: 'coneConstraint', protection: 'private', qualified_name: 'msd_sim::NLoptFrictionSolver::coneConstraint', refid: 'classmsd__sim_1_1_n_lopt_friction_solver_1afbed2e6548405f906d3042d70c865223', type: 'double'});
