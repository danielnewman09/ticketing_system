CREATE (:Compound {base_classes: [], brief_description: 'Complete kinematic state representation with 7-state quaternion formulation.', detailed_description: 'State vector: (X, Q, Ẋ, Q̇) with 14 components total. Contains position, velocity, and acceleration for both linear and angular motion. Uses quaternion representation for orientation to eliminate gimbal lock singularities. Quaternion rate Q̇ is stored directly for efficiency (avoids ω→Q̇ conversion every step). Conversion formulas: Q̇ → ω: ω = 2 * Q̄ ⊗ Q̇ (where Q̄ is conjugate) ω → Q̇: Q̇ = ½ * Q ⊗ [0, ω] docs/designs/0030_lagrangian_quaternion_physics/0030_lagrangian_quaternion_physics.puml Ticket:\\n 0030_lagrangian_quaternion_physics', file_path: '/Users/danielnewman/dev/MSD-CPP_1/msd/msd-sim/src/Physics/RigidBody/InertialState.hpp', is_abstract: false, is_final: false, kind: 'struct', line_number: 43, name: 'InertialState', qualified_name: 'msd_sim::InertialState', refid: 'structmsd__sim_1_1_inertial_state'});
CREATE (:Compound {base_classes: [], brief_description: 'Plain data structure representing current input command state.', detailed_description: 'This struct is the bridge between msd-gui (input source) and msd-sim (consumer). It decouples input representation from simulation logic. Boolean flags indicate command state; velocity/force calculation happens in the agent. Extensible for future commands (attack, interact, etc.). Thread safety: Value type (safe to copy)', file_path: '/Users/danielnewman/dev/MSD-CPP_1/msd/msd-sim/src/Agent/InputCommands.hpp', is_abstract: false, is_final: false, kind: 'struct', line_number: 21, name: 'InputCommands', qualified_name: 'msd_sim::InputCommands', refid: 'structmsd__sim_1_1_input_commands'});
CREATE (:Compound {base_classes: [], brief_description: 'Represents lower and upper bounds on a constraint\'s Lagrange multiplier.', detailed_description: 'LambdaBounds is a value type that encodes the multiplier bound semantics for different constraint types: Bilateral constraints: λ ∈ (-∞, +∞) — unconstrained multiplier Unilateral constraints: λ ∈ [0, +∞) — non-negative multiplier (inequalities) Box-constrained: λ ∈ [lo, hi] — bounded multiplier (friction cone) Factory methods provide semantic construction, and query methods enable solver dispatch without dynamic_cast. docs/designs/0043_constraint_hierarchy_refactor/0043_constraint_hierarchy_refactor.puml Ticket:\\n 0043_constraint_hierarchy_refactor', file_path: '/Users/danielnewman/dev/MSD-CPP_1/msd/msd-sim/src/Physics/Constraints/LambdaBounds.hpp', is_abstract: false, is_final: false, kind: 'struct', line_number: 25, name: 'LambdaBounds', qualified_name: 'msd_sim::LambdaBounds', refid: 'structmsd__sim_1_1_lambda_bounds'});
