CREATE (:Compound {base_classes: [], brief_description: 'Orthonormal tangent frame {t1, t2} for a contact normal.', detailed_description: 'Represents the two orthonormal tangent directions perpendicular to a contact normal. Used by FrictionConstraint to define friction constraint directions. Invariants (enforced by TangentBasis::computeTangentBasis): ||t1|| = 1, ||t2|| = 1 (unit length) t1 · t2 = 0 (orthogonal) t1 · n = 0, t2 · n = 0 (perpendicular to normal) Thread safety: Value type, safe to copy across threads Error handling: Constructor validates unit length (throws std::invalid_argument if violated) docs/designs/0035a_tangent_basis_and_friction_constraint/0035a_tangent_basis_and_friction_constraint.puml Ticket:\\n 0035a_tangent_basis_and_friction_constraint', file_path: '/Users/danielnewman/dev/MSD-CPP_1/msd/msd-sim/src/Physics/Collision/TangentBasis.hpp', is_abstract: false, is_final: false, kind: 'struct', line_number: 35, name: 'TangentFrame', qualified_name: 'msd_sim::TangentFrame', refid: 'structmsd__sim_1_1_tangent_frame'});
