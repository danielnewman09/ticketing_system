CREATE (:Compound {base_classes: ['cpp_sqlite::BaseTransferObject'], brief_description: 'Complete collision result record for a body pair at one frame.', detailed_description: 'Captures collision geometry (normal, penetration depth) and a manifold of up to 4 contact points via a RepeatedField of ContactPointRecord . Body/frame context is stored here; individual ContactPointRecords are pure geometry sub-records. Ticket:\\n 0056a_collision_force_transfer_records', file_path: '/Users/danielnewman/dev/MSD-CPP_1/msd/msd-transfer/src/CollisionResultRecord.hpp', is_abstract: false, is_final: false, kind: 'struct', line_number: 33, name: 'CollisionResultRecord', qualified_name: 'msd_transfer::CollisionResultRecord', refid: 'structmsd__transfer_1_1_collision_result_record'});
CREATE (:Compound {base_classes: ['cpp_sqlite::BaseTransferObject'], brief_description: 'Transfer record for contact constraint state.', detailed_description: 'Records the geometry and parameters of a contact constraint after constraint creation. Used for debugging constraint solver behavior and validating contact detection. Note: All vector fields (normal, lever arms) are Vector3DRecord (directions), not CoordinateRecord (points), to avoid globalToLocal overload issues.', file_path: '/Users/danielnewman/dev/MSD-CPP_1/msd/msd-transfer/src/ContactConstraintRecord.hpp', is_abstract: false, is_final: false, kind: 'struct', line_number: 22, name: 'ContactConstraintRecord', qualified_name: 'msd_transfer::ContactConstraintRecord', refid: 'structmsd__transfer_1_1_contact_constraint_record'});
CREATE (:Compound {base_classes: ['cpp_sqlite::BaseTransferObject'], brief_description: 'Per-contact-point geometry sub-record.', detailed_description: 'Pure geometry record storing contact locations on both bodies. Body/frame context lives in the parent CollisionResultRecord . Replaces ContactRecord which had body IDs, frame FK, and contact_index baked in as a standalone per-row record. Ticket:\\n 0056a_collision_force_transfer_records', file_path: '/Users/danielnewman/dev/MSD-CPP_1/msd/msd-transfer/src/ContactPointRecord.hpp', is_abstract: false, is_final: false, kind: 'struct', line_number: 28, name: 'ContactPointRecord', qualified_name: 'msd_transfer::ContactPointRecord', refid: 'structmsd__transfer_1_1_contact_point_record'});
CREATE (:Compound {base_classes: ['cpp_sqlite::BaseTransferObject'], brief_description: 'Database record for a 3D spatial coordinate.', detailed_description: 'Stores the x, y, z components of an msd_sim::Coordinate as individual scalar doubles for human-readable database inspection and queryability.', file_path: '/Users/danielnewman/dev/MSD-CPP_1/msd/msd-transfer/src/CoordinateRecord.hpp', is_abstract: false, is_final: false, kind: 'struct', line_number: 18, name: 'CoordinateRecord', qualified_name: 'msd_transfer::CoordinateRecord', refid: 'structmsd__transfer_1_1_coordinate_record'});
CREATE (:Compound {base_classes: ['cpp_sqlite::BaseTransferObject'], brief_description: 'Database record for per-body energy values.', detailed_description: 'Stores computed energy components for a single rigid body at a given simulation frame. Uses ForeignKey<AssetInertialStaticRecord> for body identification and ForeignKey<SimulationFrameRecord> for temporal association with the recording frame. Energy components: linear_ke: Linear kinetic energy KE = 0.5 * m * v^2 [J] rotational_ke: Rotational kinetic energy KE = 0.5 * omega^T * I_world * omega [J] potential_e: Gravitational potential energy PE = -m * (g . r) [J] total_e: Total mechanical energy E = KE_lin + KE_rot + PE [J] msd_sim::EnergyTracker Ticket:\\n 0039a_energy_tracking_diagnostic_infrastructure Ticket:\\n 0056i_static_asset_recording_and_fk', file_path: '/Users/danielnewman/dev/MSD-CPP_1/msd/msd-transfer/src/EnergyRecord.hpp', is_abstract: false, is_final: false, kind: 'struct', line_number: 35, name: 'EnergyRecord', qualified_name: 'msd_transfer::EnergyRecord', refid: 'structmsd__transfer_1_1_energy_record'});
CREATE (:Compound {base_classes: ['cpp_sqlite::BaseTransferObject'], brief_description: 'Database record bundling force and torque as composed sub-records.', detailed_description: 'Groups a ForceVectorRecord and TorqueVectorRecord into a single composite record. Used by AssetDynamicStateRecord to represent the external force/torque accumulator for a rigid body. msd_sim::ExternalForce', file_path: '/Users/danielnewman/dev/MSD-CPP_1/msd/msd-transfer/src/ExternalForceRecord.hpp', is_abstract: false, is_final: false, kind: 'struct', line_number: 23, name: 'ExternalForceRecord', qualified_name: 'msd_transfer::ExternalForceRecord', refid: 'structmsd__transfer_1_1_external_force_record'});
