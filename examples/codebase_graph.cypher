CREATE (:Compound {base_classes: [], brief_description: 'Loader for STL (STereoLithography) 3D model files.', detailed_description: 'Supports both binary and ASCII STL formats. Binary format is recommended for performance and file size. Binary STL format: 80-byte header (usually ignored) 4-byte unsigned int: triangle count For each triangle (50 bytes total): 12 bytes: normal vector (3 floats) 12 bytes: vertex 1 (3 floats) 12 bytes: vertex 2 (3 floats) 12 bytes: vertex 3 (3 floats) 2 bytes: attribute byte count (usually 0) ASCII STL format: Text-based format starting with "solid <name>" Each triangle defined with "facet normal" and three "vertex" lines Ends with "endsolid <name>"', file_path: '/Users/danielnewman/dev/MSD-CPP_1/msd/msd-assets/src/STLLoader.hpp', is_abstract: false, is_final: false, kind: 'class', line_number: 48, name: 'STLLoader', qualified_name: 'msd_assets::STLLoader', refid: 'classmsd__assets_1_1_s_t_l_loader'});
