CREATE (:Member {argsstring: '(int milliseconds)', brief_description: 'Set the current simulation time (absolute, not delta).', compound_refid: 'class_engine_wrapper', definition: 'void EngineWrapper::update', detailed_description: 'The underlying WorldModel::update(simTime) receives the absolute simulation time, not a delta. The caller is responsible for tracking cumulative time and passing an increasing value on each call. Example (60 FPS): for i in range(1, 61): engine.update(i * 16) # 16ms, 32ms, 48ms, ... milliseconds Absolute simulation time [ms]', file_path: '/Users/danielnewman/dev/MSD-CPP_1/msd/msd-pybind/src/engine_bindings.cpp', is_const: false, is_constexpr: false, is_explicit: false, is_inline: true, is_static: false, is_virtual: false, kind: 'function', line_number: 123, name: 'update', protection: 'public', qualified_name: 'EngineWrapper::update', refid: 'class_engine_wrapper_1adf3f5cbd3860f4aa6b8eb8559926464e', type: 'void'});
