CREATE (:Compound {base_classes: [], brief_description: 'Complete collision information for physics response with contact manifold.', detailed_description: 'This struct is returned by EPA when a collision is detected. It does NOT contain an \'intersecting\' boolean because: CollisionHandler returns std::optional<CollisionResult> std::nullopt indicates no collision Presence of CollisionResult implies collision exists All coordinates are in world space. Contact normal points from object A toward object B. Breaking change (Ticket 0028_epa_witness_points): Replaced single contactPoint with contactPointA and contactPointB Witness points enable accurate torque calculation (τ = r × F) Breaking change (Ticket 0029_contact_manifold_generation): Replaced contactPointA/contactPointB with contacts array Added contactCount field for number of valid contacts [1, 4] Enables multi-point collision response for improved stability docs/designs/0027a_expanding_polytope_algorithm/0027a_expanding_polytope_algorithm.puml docs/designs/0028_epa_witness_points/0028_epa_witness_points.puml docs/designs/0029_contact_manifold_generation/0029_contact_manifold_generation.puml Ticket:\\n 0027a_expanding_polytope_algorithm Ticket:\\n 0028_epa_witness_points Ticket:\\n 0029_contact_manifold_generation', file_path: '/Users/danielnewman/dev/MSD-CPP_1/msd/msd-sim/src/Physics/Collision/CollisionResult.hpp', is_abstract: false, is_final: false, kind: 'struct', line_number: 106, name: 'CollisionResult', qualified_name: 'msd_sim::CollisionResult', refid: 'structmsd__sim_1_1_collision_result'});
