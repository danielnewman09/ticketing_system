CREATE (:Member {argsstring: '(const InertialState &stateA, const InertialState &stateB, double time) const override', brief_description: 'Compute two-body Jacobian for friction constraints.', compound_refid: 'classmsd__sim_1_1_friction_constraint', definition: 'Eigen::MatrixXd msd_sim::FrictionConstraint::jacobian', detailed_description: 'Returns 2×12 matrix: Row 0: J_t1 = [t1^T, (rA×t1)^T, -t1^T, -(rB×t1)^T] Row 1: J_t2 = [t2^T, (rA×t2)^T, -t2^T, -(rB×t2)^T] Each row has structure: [v_A (3), ω_A (3), v_B (3), ω_B (3)] stateA Inertial state of body A (unused, pre-computed geometry) stateB Inertial state of body B (unused, pre-computed geometry) time Simulation time [s] (unused for friction) 2×12 Jacobian matrix', file_path: '/Users/danielnewman/dev/MSD-CPP_1/msd/msd-sim/src/Physics/Constraints/FrictionConstraint.hpp', is_const: true, is_constexpr: false, is_explicit: false, is_inline: false, is_static: false, is_virtual: true, kind: 'function', line_number: 133, name: 'jacobian', protection: 'public', qualified_name: 'msd_sim::FrictionConstraint::jacobian', refid: 'classmsd__sim_1_1_friction_constraint_1a8d8cf2e4fe7f31f3c294b9688228979c', type: 'Eigen::MatrixXd'});
