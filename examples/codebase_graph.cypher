CREATE (:Member {argsstring: '(msd_transfer::ConstraintRecordVisitor &visitor, uint32_t bodyAId, uint32_t bodyBId) const override', brief_description: 'Record constraint state via visitor pattern.', compound_refid: 'classmsd__sim_1_1_friction_constraint', definition: 'void msd_sim::FrictionConstraint::recordState', detailed_description: 'Builds a typed constraint record (ContactConstraintRecord, FrictionConstraintRecord, etc.) and dispatches to the visitor via overload resolution. The visitor decides what to do with the record (e.g., buffer to DataRecorder DAO). Enables compile-time type-safe constraint recording without dynamic_cast or std::any_cast. New constraint types extend ConstraintRecordVisitor with a new visit() overload. visitor Visitor that processes the typed constraint record bodyAId Persistent ID of body A for database FK reference bodyBId Persistent ID of body B for database FK reference (ignored for single-body) msd_transfer::ConstraintRecordVisitor msd_sim::DataRecorderVisitor', file_path: '/Users/danielnewman/dev/MSD-CPP_1/msd/msd-sim/src/Physics/Constraints/FrictionConstraint.hpp', is_const: true, is_constexpr: false, is_explicit: false, is_inline: false, is_static: false, is_virtual: true, kind: 'function', line_number: 169, name: 'recordState', protection: 'public', qualified_name: 'msd_sim::FrictionConstraint::recordState', refid: 'classmsd__sim_1_1_friction_constraint_1abad6b7c307884525c95bf6c118ec3c3e', type: 'void'});
CREATE (:Member {argsstring: '(const Vector3D &slidingDirection)', brief_description: 'Enable sliding friction mode with aligned tangent basis.', compound_refid: 'classmsd__sim_1_1_friction_constraint', definition: 'void msd_sim::FrictionConstraint::setSlidingMode', detailed_description: 'Overrides the tangent basis to align t1 with -slidingDirection (opposing motion), with t2 perpendicular to both t1 and the contact normal. This ensures lambda_t1 directly corresponds to deceleration along the sliding direction. When sliding mode is active, lambda_t1 bounds are made unilateral (>= 0) by the NLopt solver to prevent friction from accelerating in the sliding direction. slidingDirection Unit sliding direction (world frame) Thread safety: Not thread-safe (mutates tangent basis) Ticket:\\n 0069_friction_velocity_reversal', file_path: '/Users/danielnewman/dev/MSD-CPP_1/msd/msd-sim/src/Physics/Constraints/FrictionConstraint.hpp', is_const: false, is_constexpr: false, is_explicit: false, is_inline: false, is_static: false, is_virtual: false, kind: 'function', line_number: 204, name: 'setSlidingMode', protection: 'public', qualified_name: 'msd_sim::FrictionConstraint::setSlidingMode', refid: 'classmsd__sim_1_1_friction_constraint_1ac5b1cc5b21d688053a91c9aaa04c49d1', type: 'void'});
