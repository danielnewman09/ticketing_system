CREATE (:Member {argsstring: '(const std::vector< Constraint * > &constraints, const std::vector< std::reference_wrapper< const InertialState > > &states, const std::vector< double > &inverseMasses, const std::vector< Eigen::Matrix3d > &inverseInertias, size_t numBodies, double dt, const std::optional< Eigen::VectorXd > &initialLambda=std::nullopt)', brief_description: 'Solve mixed LCP using Projected Gauss-Seidel.', compound_refid: 'classmsd__sim_1_1_projected_gauss_seidel', definition: 'ProjectedGaussSeidel::SolveResult msd_sim::ProjectedGaussSeidel::solve', detailed_description: 'Accepts an interleaved [CC, FC, CC, FC, ...] constraint list. Uses ConstraintSolver::flattenConstraints() to expand multi-row constraints into per-row entries, then performs PGS sweeps. Friction rows use ball-projection (not lambdaBounds() box bounds). setNormalLambda() is NOT called during PGS sweeps (bypassed by design). constraints Interleaved ContactConstraint and FrictionConstraint ptrs states Per-body kinematic state inverseMasses Per-body inverse mass (size = numBodies) inverseInertias Per-body inverse inertia tensor (size = numBodies) numBodies Number of bodies in the system dt Timestep [s] initialLambda Warm-start vector (same size as active rows); zeros if empty or wrong size. SolveResult with bodyForces, lambdas, iterations, converged, residual', file_path: '/Users/danielnewman/dev/MSD-CPP_1/msd/msd-sim/src/Physics/Constraints/ProjectedGaussSeidel.hpp', is_const: false, is_constexpr: false, is_explicit: false, is_inline: false, is_static: false, is_virtual: false, kind: 'function', line_number: 103, name: 'solve', protection: 'public', qualified_name: 'msd_sim::ProjectedGaussSeidel::solve', refid: 'classmsd__sim_1_1_projected_gauss_seidel_1a6b2498c73c87f4f0a3258bf96eae38ec', type: 'SolveResult'});
