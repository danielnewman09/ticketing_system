CREATE (:Member {argsstring: '()', brief_description: 'Get the current simulation state for all bodies (inertial and environment).', compound_refid: 'class_engine_wrapper', definition: 'py::dict EngineWrapper::getFrameState', detailed_description: 'Returns the simulation time plus the state of every asset spawned into the world. Inertial (dynamic) bodies appear first, followed by environment (static) bodies. Each entry includes an is_environment flag so that downstream consumers can distinguish body types without additional metadata. Environment bodies have zeroed velocity and angular_velocity fields because they are immovable by definition. dict with: "simulation_time": float (seconds) "states": list of dicts each containing: "body_id": int "asset_id": int "position": {"x": float, "y": float, "z": float} "velocity": {"x": float, "y": float, "z": float} "orientation": {"w": float, "x": float, "y": float, "z": float} "angular_velocity": {"x": float, "y": float, "z": float} "is_environment": bool (false for inertial, true for environment) Ticket:\\n 0072e_live_simulation_cleanup (FR-1)', file_path: '/Users/danielnewman/dev/MSD-CPP_1/msd/msd-pybind/src/engine_bindings.cpp', is_const: false, is_constexpr: false, is_explicit: false, is_inline: true, is_static: false, is_virtual: false, kind: 'function', line_number: 152, name: 'getFrameState', protection: 'public', qualified_name: 'EngineWrapper::getFrameState', refid: 'class_engine_wrapper_1a4914e00b37a15641a7bbde15a54542b8', type: 'py::dict'});
